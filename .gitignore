# Terraform state & local config (may contain secrets / resource data)
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
.terraform/
.terraform.lock.hcl
.terraformrc
terraform.rc
crash.log
crash.*.log

# Credentials / local env
.env
.env.*

# Built provider binary & release artifacts
terraform-provider-mixpanel
terraform-provider-mixpanel_*
dist/
*.exe

# Generator: OpenAPI specs are NEVER committed (they map the API surface) — both the
# full merged spec and the pruned spec are fetched/produced locally before a regen.
# Plus stage-1 build scratch. See gen/README.md.
gen/spec/*.json
gen/build/
